# ============================================================================
# Octra Safe — Environment Variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and adjust values as needed.
# Vite automatically loads .env, .env.local, .env.{mode}, .env.{mode}.local
# All variables MUST be prefixed with VITE_ to be exposed to the browser.
# ============================================================================

# --- RPC Endpoints ---
# In development, Vite proxies /rpc/devnet and /rpc/mainnet to these URLs
# (bypasses CORS). In production, the dApp fetches these URLs directly.
# If the Octra devnet is down (502), you can override with an alternative RPC.

# Devnet RPC (default: https://devnet.octrascan.io/rpc)
VITE_DEVNET_RPC_URL=https://devnet.octrascan.io/rpc

# Mainnet RPC (default: https://octra.network/rpc)
VITE_MAINNET_RPC_URL=https://octra.network/rpc

# --- Explorer URLs ---
# Used for building explorer links (tx, address pages)

# Devnet explorer (default: https://devnet.octrascan.io)
VITE_DEVNET_EXPLORER_URL=https://devnet.octrascan.io

# Mainnet explorer (default: https://octrascan.io)
VITE_MAINNET_EXPLORER_URL=https://octrascan.io

# --- Deployed Contract Addresses ---
# After deploying contracts, paste their addresses here.
# These are loaded by src/config/contracts.ts.

# TestOCS01 token address on devnet (paste after deploying)
VITE_DEVNET_TEST_TOKEN_ADDR=

# TestOCS01 token address on mainnet (paste after deploying)
VITE_MAINNET_TEST_TOKEN_ADDR=

# OctraSafeFactory address on devnet (optional — factory is a registry)
VITE_DEVNET_FACTORY_ADDR=

# OctraSafeFactory address on mainnet
VITE_MAINNET_FACTORY_ADDR=

# --- App Config (optional) ---

# Default network on first load: 'devnet' or 'mainnet' (default: devnet)
VITE_DEFAULT_NETWORK=devnet

# Enable debug logging (default: false)
VITE_DEBUG=false
